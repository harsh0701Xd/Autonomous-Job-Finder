# .env.example
#
# Canonical reference for ALL environment variables used by this project.
#
# ── How to use ───────────────────────────────────────────────────────────────
#
#   LOCAL DEV (plain Python or docker-compose.yml):
#     cp .env.example .env
#     Fill in your API keys. Set APP_ENV=development.
#
#   PRODUCTION (EC2 + docker-compose.prod.yml):
#     cp .env.example .env.production
#     Fill in your API keys. Set APP_ENV=production and fill in Postgres fields.
#     SCP to EC2: scp .env.production ubuntu@<EC2_HOST>:~/autonomous-job-finder/.env
#
# ── GitHub Actions secrets (NOT needed in .env on the server) ────────────────
#
#   Add these once at: GitHub → repo → Settings → Secrets and variables → Actions
#
#   AWS_ACCESS_KEY_ID       — IAM key for ECR push
#   AWS_SECRET_ACCESS_KEY   — IAM secret for ECR push
#   AWS_REGION              — e.g. ap-south-1
#   ECR_REGISTRY            — e.g. 123456789012.dkr.ecr.ap-south-1.amazonaws.com
#   EC2_HOST                — Elastic IP of your EC2 instance
#   EC2_USER                — SSH user (ubuntu or ec2-user)
#   EC2_SSH_KEY             — Full contents of your PEM private key
#
# ─────────────────────────────────────────────────────────────────────────────


# ── Application ───────────────────────────────────────────────────────────────

# Controls checkpointer and CORS behaviour.
# development → in-memory LangGraph checkpointer, no Postgres needed.
# production  → Postgres checkpointer, requires DATABASE_URL below.
APP_ENV=development

# Log verbosity for the FastAPI container. INFO | DEBUG | WARNING | ERROR
LOG_LEVEL=INFO


# ── LLM / Pipeline API keys ───────────────────────────────────────────────────

# Anthropic — Claude Sonnet (parser, recommender, HyDE JD generation, ranker)
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI — voyage-3 embeddings (HyDE prefilter, Agent 5b)
# Get your key at: https://dash.voyageai.com
VOYAGE_API_KEY=pa-...

# ── Job source API keys (RapidAPI) ───────────────────────────────────────────
#
# Each source uses its own key variable. All four are the same RapidAPI key
# IF you subscribed to each product under the same RapidAPI account —
# but the env vars are intentionally separate so you can enable/disable
# individual sources without touching code.
#
# At minimum, set JSEARCH_API_KEY. The others are optional and only used
# if the corresponding source is enabled in agents/job_search/sources/.

# JSearch — primary job listings source (required)
# Subscribe at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=

# Active Jobs DB — supplementary source (optional)
# Subscribe at: https://rapidapi.com/bebity/api/active-jobs-db
ACTIVE_JOBS_DB_API_KEY=

# Jobs Search API — supplementary source (optional)
# Subscribe at: https://rapidapi.com/fantastic-jobs/api/jobs-search-api
JOBS_SEARCH_API_KEY=

# Techmap Daily International Job Postings — supplementary source (optional)
# Subscribe at: https://rapidapi.com/techmap-io-techmap-io-default/api/daily-international-job-postings
TECHMAP_API_KEY=

# LinkedIn Job Search API via RapidAPI — supplementary source (optional)
# Subscribe at: https://rapidapi.com/fantastic-jobs/api/linkedin-job-search-api
LINKEDIN_JOBS_API_KEY=


# ── Observability ─────────────────────────────────────────────────────────────

# MLflow tracking server URL.
# Local dev (plain Python): http://localhost:5000  (run: mlflow ui --port 5000)
# Local dev (Docker):       http://localhost:5000
# Production (Docker):      http://mlflow:5000     ← Docker service name
MLFLOW_TRACKING_URI=http://localhost:5000

# MLflow experiment name (optional — defaults to "autonomous-job-finder").
MLFLOW_EXPERIMENT=autonomous-job-finder

# LangSmith tracing (optional). Set LANGSMITH_TRACING=true to enable.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=autonomous-job-finder


# ── Database (production only — leave blank for local dev) ────────────────────

# Postgres connection string — only read when APP_ENV=production.
# Format: postgresql://<user>:<password>@<host>:<port>/<db>
# Production value: postgresql://jobfinder:<POSTGRES_PASSWORD>@postgres:5432/jobfinder
DATABASE_URL=

# Password for the Postgres jobfinder user.
# Used by the api container, mlflow, and the postgres container itself.
# Only required when APP_ENV=production or running docker-compose.prod.yml.
POSTGRES_PASSWORD=
