# Secrets -- never bake API keys into an image layer
.env
.env.*
*.env

# Version control
.git
.gitignore
.gitattributes

# Python cache
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache
.mypy_cache
.ruff_cache

# Test artefacts
tests/
htmlcov/
.coverage
coverage.xml

# MLflow local run data (server uses a volume, not baked-in files)
mlruns/
mlartifacts/

# Local virtual environments
.venv
venv/
env/

# OS noise
.DS_Store
Thumbs.db

# Editor configs
.vscode/
.idea/
*.swp

# Docs / markdown (not needed in image)
*.md
docs/

# Dev-only compose files
docker-compose.prod.yml

# Node (if any frontend tooling is ever added)
node_modules/
